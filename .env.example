# ==========================================
# DRIPMATE BACKEND - Environment Variables
# ==========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ==========================================
# REQUIRED
# ==========================================

# Anthropic API key for coffee bag image analysis (Claude AI)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend API key for transactional emails (beta tokens, waitlist confirmation)
# Get yours at: https://resend.com/
RESEND_API_KEY=re_your_resend_api_key_here

# ==========================================
# PRODUCTION
# ==========================================

# Set to "production" for production deployment
# When set to "production", PostgreSQL is used instead of SQLite
NODE_ENV=development

# PostgreSQL connection string (required in production)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/dripmate

# Comma-separated list of allowed frontend origins for CORS
# IMPORTANT: Must be set in production or CORS will be misconfigured!
ALLOWED_ORIGINS=https://dripmate.app

# Frontend URL used in email links (beta token button, magic link button)
# Default: https://dripmate.app
FRONTEND_URL=https://dripmate.app

# ==========================================
# OPTIONAL
# ==========================================

# Server port (default: 3000)
PORT=3000

# SQLite database file path (only used in development when DATABASE_URL is not set)
# Default: ./db/dripmate.db
DATABASE_PATH=./db/dripmate.db

# Password for admin whitelist/waitlist management endpoints (X-Admin-Token session auth)
ADMIN_PASSWORD=your_admin_password_here

# Maximum number of self-signup beta spots before the waitlist kicks in.
# Default: 200 if not set.
BETA_INVITE_CAP=200
